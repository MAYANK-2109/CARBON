{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "outDir": "./dist/cjs",
        "rootDir": "./src",
        "composite": false,
        "declaration": false,
        "declarationMap": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "src/**/*.test.ts",
        "src/**/*.spec.ts"
    ]
}