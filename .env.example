# =============================================================
# CARBON Footprint Assistant — Environment Variables Example
# =============================================================
# Copy this file to `.env` in the project root and fill in values.
# NEVER commit the actual `.env` file — it is gitignored.
# =============================================================

# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────
# Use a local URI for dev or your MongoDB Atlas connection string.
MONGODB_URI=mongodb://localhost:27017/carbon-footprint

# ─── JWT Secrets ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_at_least_32_char_random_string
JWT_REFRESH_SECRET=replace_with_another_32_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ───────────────────────────────────────────────
# Must be exactly 64 hex characters (256-bit AES key).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_char_string_here_00000000000000000000000000000000

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGIN=http://localhost:5173

# ─── Google Gemini AI ─────────────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Client (Vite) ────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
